{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cloudflared Access Manager",
  "version": "0.3.1",
  "identifier": "com.mewisme.cfm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Cloudflared Access Manager",
        "width": 800,
        "height": 700,
        "minWidth": 720,
        "minHeight": 560,
        "devtools": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 300,
        "height": 300,
        "decorations": false,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:cfm.sqlite3"
      ]
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/mewisme/cfm/releases/latest/download/latest.json"
      ]
    }
  }
}
